# CashBryan.com — environment variables (names only; set values in Vercel).

# OpenAI key for the public site assistant (server-only; never NEXT_PUBLIC_).
# When unset, the assistant serves built-in canned responses (no upstream calls).
OPENAI_API_KEY=

# Optional model override. Default: gpt-4.1-mini (see app/api/chat/route.ts).
OPENAI_MODEL=

# Kill switch for the assistant: set to 1 (or true/yes) to disable it.
# The route then returns a controlled 503 and makes no OpenAI request.
# Note: on Vercel, changing an env var requires a redeploy to take effect.
CHAT_ASSISTANT_DISABLED=

# Optional comma-separated extra allowed origins for the chat endpoint.
# cashbryan.com, www, localhost, and *.vercel.app previews are always allowed.
CHAT_ALLOWED_ORIGINS=

# Contact email override used in assistant replies and site metadata.
BRYAN_EMAIL=
